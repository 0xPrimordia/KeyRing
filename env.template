# KeyRing Protocol Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# HEDERA CONFIGURATION
# =============================================================================

# Hedera Network (testnet or mainnet)
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Hedera Testnet Operator Account (for API operations)
HEDERA_TESTNET_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_TESTNET_PRIVATE_KEY=302e020100300506032b657004220420YOUR_PRIVATE_KEY_HERE

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase Project URL (public - safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (secret - server-side only)
SUPABASE_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY_HERE

# =============================================================================
# WALLETCONNECT CONFIGURATION
# =============================================================================

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# =============================================================================
# INSTRUCTIONS
# =============================================================================

# 1. HEDERA SETUP:
#    - Create a Hedera testnet account at https://portal.hedera.com
#    - Get your Account ID (format: 0.0.123456)
#    - Get your Private Key (DER format starting with 302e020100)

# 2. SUPABASE SETUP:
#    - Create a project at https://supabase.com/dashboard
#    - Go to Settings → API
#    - Copy Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - Copy Service Role Key → SUPABASE_SECRET

# 3. WALLETCONNECT SETUP:
#    - Create a project at https://cloud.walletconnect.com
#    - Copy Project ID → NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID

# 4. DATABASE SETUP:
#    - Run: npm run test:db (to test connection)
#    - Run SQL from supabase/schema.sql in Supabase dashboard
#    - Run: npm run test:db (to verify tables)

# =============================================================================
# SECURITY NOTES
# =============================================================================

# ✅ SAFE FOR CLIENT-SIDE (NEXT_PUBLIC_*):
# - NEXT_PUBLIC_HEDERA_NETWORK
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID

# ⚠️  SERVER-SIDE ONLY (NEVER EXPOSE):
# - HEDERA_TESTNET_ACCOUNT_ID
# - HEDERA_TESTNET_PRIVATE_KEY
# - SUPABASE_SECRET

