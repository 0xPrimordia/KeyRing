# KeyRing Protocol Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# HEDERA CONFIGURATION
# =============================================================================

# Hedera Network (testnet or mainnet)
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Hedera Operator Accounts (for API operations)
# Testnet credentials
HEDERA_TESTNET_ACCOUNT_ID=0.0.YOUR_TESTNET_ACCOUNT_ID
HEDERA_TESTNET_PRIVATE_KEY=YOUR_TESTNET_PRIVATE_KEY_HERE

# Mainnet credentials  
HEDERA_MAINNET_ACCOUNT_ID=0.0.YOUR_MAINNET_ACCOUNT_ID
HEDERA_MAINNET_PRIVATE_KEY=YOUR_MAINNET_PRIVATE_KEY_HERE

# Project Registry Topic IDs (HCS-2 indexed topics for project registration)
# These are created automatically by utils/send-test-project.ts if not set
PROJECT_REGISTRY_TOPIC_TESTNET=0.0.0
PROJECT_REGISTRY_TOPIC_MAINNET=0.0.0

# LYNX Rewards Token (HTS) - signer rewards (0.5-1 LYNX per signature)
# Used by NEXT_PUBLIC_MAINNET_KYRNG / NEXT_PUBLIC_TESTNET_KYRNG
KYRNG_TOKEN_ID_MAINNET=0.0.10046117
KYRNG_TOKEN_ID_TESTNET=0.0.5142390

# =============================================================================
# BOOST PROJECT / THRESHOLD LIST TESTING
# =============================================================================

# Threshold List Account (2-of-3 multisig for testing)
# Created by: npm run hedera:threshold
# View on HashScan: https://hashscan.io/testnet/account/0.0.7102741
# Contains 3 keys, requires 2 signatures for transactions
THRESHOLD_LIST_ACCOUNT_TESTNET=0.0.7102741

# Test Scheduled Transaction
# Created by: npm run boost:create
# View on HashScan: https://hashscan.io/testnet/schedule/0.0.7102743
# Transfers 0.1 HBAR from threshold list to operator
# Requires 2-of-3 threshold list signatures to execute
TEST_SCHEDULE_ID_TESTNET=0.0.7102743

# Threshold Keys (for reference - used in utils/createThresholdList.ts)
# Key 1 (DER): 302a300506032b65700321005f2a9826bef0c082e6e885c46022969da4120f5143b9c5413f79eabbba0cb399
# Key 2 (raw): 59345a9c8b6112ccc1a3c636d6bc0d2c42477013f3d9f107f0db39b53a5cbb07
# Key 3 (raw): 0158a26e9dc97312aaf7e8811f3223e5a30b6676a0b58518d062d38418de8eb8

# BoostProject Smart Contract
# View on HashScan: https://hashscan.io/testnet/contract/0.0.7097984
# Used for tracking boost transactions on-chain
BOOST_PROJECT_CONTRACT_ID=0.0.7097984

# =============================================================================
# VALIDATION AGENT (keyring-signer-agent)
# =============================================================================

# HCS topic where the agent posts rejection feedback (optional)
PROJECT_REJECTION_TOPIC=

# HCS topic where the agent posts validation events (optional)
PROJECT_VALIDATOR_TOPIC=

# Agent public key for server-side validation (optional)
VALIDATION_AGENT_PUBLIC_KEY=

# Agent public key for client-side badge display (optional, same value as above)
# Used to show "Validator Agent" badge on signatures in schedule detail
NEXT_PUBLIC_VALIDATION_AGENT_PUBLIC_KEY=

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase Project URL (public - safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (secret - server-side only)
SUPABASE_SECRET=YOUR_SERVICE_ROLE_KEY_HERE

# =============================================================================
# WALLETCONNECT CONFIGURATION
# =============================================================================

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# =============================================================================
# INSTRUCTIONS
# =============================================================================

# 1. HEDERA SETUP:
#    - For Testnet: Create account at https://portal.hedera.com
#    - For Mainnet: Use your production Hedera account
#    - Get your Account ID (format: 0.0.123456)
#    - Get your Private Key (DER format starting with 302e020100)
#    - Set NEXT_PUBLIC_HEDERA_NETWORK to "testnet" or "mainnet"
#    - Run utils/send-test-project.ts to create project registry topics

# 2. SUPABASE SETUP:
#    - Create a project at https://supabase.com/dashboard
#    - Go to Settings → API
#    - Copy Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - Copy Service Role Key → SUPABASE_SECRET

# 3. WALLETCONNECT SETUP:
#    - Create a project at https://cloud.walletconnect.com
#    - Copy Project ID → NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID

# 4. DATABASE SETUP:
#    - Run: npm run test:db (to test connection)
#    - Run SQL from supabase/schema.sql in Supabase dashboard
#    - Run: npm run test:db (to verify tables)
#
# 5. BOOST PROJECT TESTING (Threshold Lists & Scheduled Transactions):
#    - Run: npm run hedera:threshold (creates 2-of-3 threshold list account)
#    - Run: npm run boost:create (creates test scheduled transaction)
#    - Visit: http://localhost:3000/signer-dashboard (sign with HashPack)
#    - Monitor: https://hashscan.io/testnet/schedule/[SCHEDULE_ID]

# =============================================================================
# SECURITY NOTES
# =============================================================================

# ✅ SAFE FOR CLIENT-SIDE (NEXT_PUBLIC_*):
# - NEXT_PUBLIC_HEDERA_NETWORK
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
# - NEXT_PUBLIC_VALIDATION_AGENT_PUBLIC_KEY (public key for badge display)

# ⚠️  SERVER-SIDE ONLY (NEVER EXPOSE):
# - HEDERA_TESTNET_ACCOUNT_ID
# - HEDERA_TESTNET_PRIVATE_KEY
# - HEDERA_MAINNET_ACCOUNT_ID
# - HEDERA_MAINNET_PRIVATE_KEY
# - SUPABASE_SECRET
# - PROJECT_REGISTRY_TOPIC_TESTNET
# - PROJECT_REGISTRY_TOPIC_MAINNET
# - PROJECT_REJECTION_TOPIC
# - PROJECT_VALIDATOR_TOPIC

